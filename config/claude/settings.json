{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(uv:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(eza:*)",
      "Bash(bat:*)",
      "Bash(fd:*)",
      "Bash(fzf:*)",
      "Bash(rg:*)",
      "Bash(chmod:*)",
      "Bash(ln:*)",
      "Bash(ls:*)",
      "Bash(env:*)",
      "Bash(code:*)",
      "Bash(python:*)",
      "WebSearch",
      "WebFetch",
      "Read(/Users/*/*)",
      "Glob(/Users/*/*)",
      "Grep(/Users/*/*)"
    ],
    "deny": [
      "Bash(rm -rf *)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/bin/bash $HOME/.claude/statusline.sh"
  },
  "notifications": true,
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true
  }
}
