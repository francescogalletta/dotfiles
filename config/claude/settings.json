{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(uv:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(eza:*)",
      "Bash(bat:*)",
      "Bash(fd:*)",
      "Bash(fzf:*)",
      "Bash(rg:*)",
      "Bash(chmod:*)",
      "Bash(ln:*)",
      "Bash(ls:*)",
      "Bash(env:*)",
      "Bash(code:*)",
      "Bash(python:*)",
      "WebSearch",
      "WebFetch",
      "Read(/Users/*/*)",
      "Glob(/Users/*/*)",
      "Grep(/Users/*/*)"
    ],
    "deny": [
      "Bash(rm -rf *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "test -f TASKS.md && echo 'This is a managed project. Run /project-resume to orient yourself before doing any work.'",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/bin/bash $HOME/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "cli-anything@cli-anything": true,
    "discord@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "cli-anything": {
      "source": {
        "source": "github",
        "repo": "HKUDS/CLI-Anything"
      }
    }
  },
  "voiceEnabled": true,
  "notifications": true
}
