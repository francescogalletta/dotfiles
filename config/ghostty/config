font-family = JetBrains Mono
font-size = 14

theme = catppuccin-mocha
background-opacity = 0.80
background-blur = true

window-padding-x = 12
window-padding-y = 8

window-decoration = auto
macos-titlebar-style = tabs

# Option key as Alt — enables Option+Left/Right (word jump), Option+Backspace (delete word)
macos-option-as-alt = true

# Links — Cmd+click any URL to open in browser
link-url = true

# Scrolling
mouse-scroll-multiplier = 2

# Window behavior
confirm-close-surface = false

# Notifications — enable system bell (e.g. dock bounce on macOS)
bell-features = system

# Keybindings
keybind = super+k=toggle_command_palette
keybind = alt+shift+left=previous_tab
keybind = alt+shift+right=next_tab

