font-family = JetBrains Mono
font-size = 14

theme = catppuccin-mocha
background-opacity = 0.80
background-blur = true

window-padding-x = 12
window-padding-y = 8

window-decoration = auto
macos-titlebar-style = tabs

# Option key as Alt — enables Option+Left/Right (word jump), Option+Backspace (delete word)
macos-option-as-alt = true

# Links — Cmd+click any URL to open in browser
link-url = true

# Scrolling
mouse-scroll-multiplier = 2

# Window behavior
confirm-close-surface = false

# Notifications — enable system bell (e.g. dock bounce on macOS)
bell-features = system

# Keybindings — unified across Ghostty, Warp, cmux, Cursor
# Command palette
keybind = super+shift+p=toggle_command_palette
keybind = super+k=unbind

# Tabs (Alt+Shift)
keybind = alt+shift+left=previous_tab
keybind = alt+shift+right=next_tab

# Pane splits (Ctrl+Shift)
keybind = ctrl+shift+r=new_split:right
keybind = ctrl+shift+d=new_split:down
keybind = ctrl+shift+w=close_surface

# Pane focus (Ctrl+Alt)
keybind = ctrl+alt+left=goto_split:left
keybind = ctrl+alt+right=goto_split:right
keybind = ctrl+alt+up=goto_split:top
keybind = ctrl+alt+down=goto_split:bottom

