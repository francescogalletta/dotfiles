// Global tasks — available in all projects.
// Project-specific tasks go in .zed/tasks.json at project root.
[
  {
    "label": "Build",
    "command": "make build",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "on_success",
    "save": "all"
  },
  {
    "label": "Test",
    "command": "make test",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "never",
    "save": "all"
  },
  {
    "label": "Dev server",
    "command": "make dev",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "never",
    "save": "all"
  },
  {
    "label": "Logs",
    "command": "make logs",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "no_focus",
    "hide": "never"
  },
  {
    "label": "Stop",
    "command": "make stop",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "no_focus",
    "hide": "on_success"
  },
  {
    "label": "Docker shell",
    "command": "make shell",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "never"
  }
]
