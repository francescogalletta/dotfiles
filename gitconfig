[init]
	defaultBranch = main

[core]
	excludesFile = ~/.config/git/ignore

[include]
	path = ~/.gitconfig.local

[alias]
	s = status
	co = checkout
	br = branch
	ci = commit
	lg = log --oneline --graph --decorate --all
	d = diff
	ds = diff --staged

[pull]
	rebase = true

[push]
	autoSetupRemote = true

# [user] is in ~/.gitconfig.local (written by install.sh)
